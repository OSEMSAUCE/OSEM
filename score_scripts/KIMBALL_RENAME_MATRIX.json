{
  "recommendation": {
    "namingStyle": "camelCase",
    "modelingStyle": "Kimball semantics over a relational core",
    "summary": "Keep Prisma-style camelCase, use Kimball concepts for fact-like and dimension-like roles, and rename only where names obscure analytical purpose."
  },
  "implementationPhases": [
    {
      "phase": 1,
      "title": "Define each table",
      "steps": [
        "Select the business process.",
        "Declare the grain.",
        "Identify the dimensions.",
        "Identify the facts."
      ]
    },
    {
      "phase": 2,
      "title": "Freeze naming rules",
      "rules": {
        "Key": "deterministic business key",
        "Id": "opaque/generated technical identifier",
        "TypeOrCode": "controlled categorical value",
        "AtOrTs": "timestamp fields"
      },
      "goal": [
        "stop mixing semantics",
        "make future schema changes consistent",
        "avoid renaming the same concept twice"
      ]
    },
    {
      "phase": 3,
      "title": "Clean up the analytics layer first",
      "actions": [
        "rename analytical tables away from helper",
        "convert analytics fields from snake_case to camelCase",
        "standardize timestamp field naming"
      ]
    },
    {
      "phase": 4,
      "title": "Rename business keys consistently",
      "actions": [
        "rename business-key primary keys such as projectKey to projectKey",
        "rename matching foreign keys at the same time",
        "rename polymorphic references like parentKey to parentKey if they store row keys"
      ]
    },
    {
      "phase": 5,
      "title": "Re-evaluate enums vs lookup tables",
      "rule": "Keep as enum if small, stable, and code-owned; convert to lookup if it needs descriptions, sort order, grouping, aliases, or business-managed changes."
    },
    {
      "phase": 6,
      "title": "Consider surrogate IDs only if needed",
      "futureState": {
        "projectKey": "opaque technical primary key",
        "projectKey": "business key"
      }
    }
  ],
